# Required
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY

# Slack (set automatically when using `slack run`, or set manually for python3 app.py)
# SLACK_APP_TOKEN=xapp-...
# SLACK_BOT_TOKEN=xoxb-...

# Recommended for Real-Time Search API (assistant.search.context without action_token).
# Install the app to your workspace and copy User OAuth Token from OAuth & Permissions.
# SLACK_USER_TOKEN=xoxp-...

# Optional: Google Sheet curriculum source (see docs/google_sheet_setup.md)
# GOOGLE_SHEET_ID=your_sheet_id_from_url
# GOOGLE_SHEET_MENTOR_GID=1

# Optional, uncomment and set when using a custom Slack instance.
# SLACK_API_URL=YOUR_SLACK_API_URL
